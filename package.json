{
  "name": "my-php-electron",
  "version": "1.0.0",
  "description": "Desktop wrapper for XAMPP/PHP applications",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "author": "Your Name",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.yourcompany.phpelectron",
    "productName": "My PHP Electron App",
    "directories": {
      "output": "dist"
    },
    "asar": false,
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    },
    "extraFiles": [
      {
        "from": "frontend/",
        "to": "frontend/",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "backend/",
        "to": "backend/",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}